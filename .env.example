# ============================================================
# Hallucination Detection Middleware — Configuration
# Copy this file to .env and adjust values as needed.
# ============================================================

# ---- LLM Provider -----------------------------------------
# "ollama"    — free, runs locally (recommended for development)
# "anthropic" — paid API, fastest and most accurate
LLM_PROVIDER=ollama

# ---- Ollama (free local LLM) ------------------------------
# Requires: ollama serve  +  ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1
EXTRACTOR_MODEL=llama3.2
VERIFIER_MODEL=llama3.2

# ---- Anthropic API (only if LLM_PROVIDER=anthropic) -------
# ANTHROPIC_API_KEY=sk-ant-...
# EXTRACTOR_MODEL=claude-haiku-4-5-20251001
# VERIFIER_MODEL=claude-haiku-4-5-20251001

# ---- Proxy server -----------------------------------------
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# ---- Detection thresholds ---------------------------------
# Claim confidence below BLOCK_THRESHOLD → BLOCK response
# Claim confidence below FLAG_THRESHOLD  → FLAG for review
BLOCK_THRESHOLD=0.25
FLAG_THRESHOLD=0.60

# ---- Knowledge base (ChromaDB) ----------------------------
KB_PERSIST_DIR=./chroma_db
KB_COLLECTION_NAME=authoritative_docs
KB_MIN_RELEVANCE=0.35
KB_CHUNK_SIZE=512
KB_CHUNK_OVERLAP=64

# ---- Performance (tune these to speed up responses) -------
# Fewer claims = fewer LLM calls = faster responses
MAX_CLAIMS_PER_RESPONSE=8

# Docs retrieved per query (lower = faster)
KB_TOP_K=3

# Query variants per claim (lower = fewer LLM calls)
MULTI_QUERY_ENABLED=true
MULTI_QUERY_COUNT=2

# Cross-encoder reranking (accurate but slow — disable for speed)
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=3

# Ensemble verification (runs 2 models — very slow, high accuracy)
ENSEMBLE_FOR_CRITICAL=false
ENSEMBLE_MODEL=llama3.2

# ---- Verification cache -----------------------------------
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
# REDIS_URL=redis://localhost:6379  # Leave empty to use in-memory cache

# ---- Runtime ----------------------------------------------
MAX_WORKERS=4
REQUEST_TIMEOUT=480.0
LOG_LEVEL=INFO

# ---- Audit trail ------------------------------------------
AUDIT_LOG_PATH=./audit_trail.jsonl
