# ============================================================
# Hallucination Detection Middleware v2.1 — FREE Edition
# No API key required for core features. Uses local Ollama LLM.
# ============================================================

# ---- LLM Provider ----
# "ollama" = free local LLM (default)
# "anthropic" = paid Anthropic API
LLM_PROVIDER=ollama

# ---- Ollama settings (free, local) ----
OLLAMA_BASE_URL=http://localhost:11434/v1
# Model to use — must be pulled first: ollama pull mistral:7b
EXTRACTOR_MODEL=mistral:7b
VERIFIER_MODEL=mistral:7b

# ---- Proxy server ----
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# ---- Decision thresholds ----
BLOCK_THRESHOLD=0.25
FLAG_THRESHOLD=0.60

# ---- Knowledge base ----
KB_PERSIST_DIR=./chroma_db
KB_COLLECTION_NAME=authoritative_docs
KB_TOP_K=3
KB_MIN_RELEVANCE=0.35
KB_CHUNK_SIZE=512
KB_CHUNK_OVERLAP=64

# ---- Hybrid search (BM25 + vector) ----
BM25_ENABLED=true
BM25_WEIGHT=0.40

# ---- Multi-query retrieval ----
MULTI_QUERY_ENABLED=true
MULTI_QUERY_COUNT=2
HYDE_ENABLED=false

# ---- Cross-encoder re-ranking ----
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=3

# ---- Verification cache ----
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
REDIS_URL=

# ---- Ensemble verification ----
ENSEMBLE_FOR_CRITICAL=false
ENSEMBLE_MODEL=mistral:7b

# ---- Runtime ----
MAX_WORKERS=4
REQUEST_TIMEOUT=480.0
LOG_LEVEL=INFO

# ---- Extraction ----
MAX_CLAIMS_PER_RESPONSE=8
ANNOTATE_VERIFIED=true

# ---- Audit log ----
AUDIT_LOG_PATH=./audit_trail.jsonl

# ============================================================
# NEW in v2.1 — Web Search + Wikipedia + LangChain
# ============================================================

# ---- Tavily Web Search (optional, free tier at tavily.com) ----
# Get your free key at: https://tavily.com
# Leave empty to use DuckDuckGo fallback (no key needed)
TAVILY_API_KEY=

# ---- DuckDuckGo fallback ----
# Always available, no key required — used when Tavily is unavailable
# No config needed.

# ---- Wikipedia ingestion ----
# No key needed. Use the ingest_from_wikipedia() function directly:
#   python -c "from hallucination_middleware import ingest_from_wikipedia; ingest_from_wikipedia('Albert Einstein')"

# ---- LangChain (optional orchestration) ----
# Uses same Ollama setup above. Install: pip install langchain langchain-openai
# No extra config needed — reads LLM_PROVIDER, OLLAMA_BASE_URL, VERIFIER_MODEL above.

# ---- Anthropic (optional, only if LLM_PROVIDER=anthropic) ----
# ANTHROPIC_API_KEY=your_key_here
